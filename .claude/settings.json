{
    "permissions": {
        "allow": ["mcp__grep__*", "mcp__plugin_context7_*"]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/post-edit.sh"
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {
        "context7@claude-plugins-official": true
    },
    "enabledMcpjsonServers": ["grep"]
}
